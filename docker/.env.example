# .env - Keystone Edge Environment Configuration
# Copy this file to .env and modify as needed

# -----------------------------------------------------------------------------
# Factory ID
# -----------------------------------------------------------------------------
KEYSTONE_FACTORY_ID=factory-archebase

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
KEYSTONE_MODE=edge
KEYSTONE_BIND_ADDR=:9999
KEYSTONE_READ_TIMEOUT=30
KEYSTONE_WRITE_TIMEOUT=30
KEYSTONE_SHUTDOWN_TIMEOUT=10

# -----------------------------------------------------------------------------
# MySQL Configuration
# -----------------------------------------------------------------------------
KEYSTONE_MYSQL_HOST=localhost
KEYSTONE_MYSQL_PORT=3306
KEYSTONE_MYSQL_USER=keystone
KEYSTONE_MYSQL_PASSWORD=keystone
KEYSTONE_MYSQL_DATABASE=keystone
KEYSTONE_DB_MAX_OPEN_CONNS=25
KEYSTONE_DB_MAX_IDLE_CONNS=5
KEYSTONE_DB_CONN_MAX_LIFETIME=300

# -----------------------------------------------------------------------------
# MinIO Configuration (S3-compatible storage)
# -----------------------------------------------------------------------------
KEYSTONE_MINIO_ENDPOINT=localhost:9000
KEYSTONE_MINIO_ACCESS_KEY=keystone
KEYSTONE_MINIO_SECRET_KEY=keystone123
#KEYSTONE_MINIO_BUCKET=edge-factory-shanghai
KEYSTONE_MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Cloud Sync Configuration
# -----------------------------------------------------------------------------
KEYSTONE_SYNC_ENABLED=true
KEYSTONE_SYNC_BATCH_SIZE=100
KEYSTONE_SYNC_MAX_RETRIES=5
KEYSTONE_CLOUD_AUTH_ENDPOINT=127.0.0.1:50051
KEYSTONE_CLOUD_GATEWAY_ENDPOINT=127.0.0.1:50053
KEYSTONE_CLOUD_SITE_ID=42
KEYSTONE_CLOUD_API_SECRET=local-secret-placeholder
KEYSTONE_SYNC_WORKER_INTERVAL=15
KEYSTONE_SYNC_REQUEST_TIMEOUT=15
KEYSTONE_SYNC_OSS_TIMEOUT=120
KEYSTONE_SYNC_MAX_CONCURRENT=1
KEYSTONE_SYNC_RETRY_BASE_SEC=30
KEYSTONE_SYNC_RETRY_MAX_SEC=1800
KEYSTONE_SYNC_RETRY_JITTER_SEC=30

# -----------------------------------------------------------------------------
# QA Engine Configuration
# -----------------------------------------------------------------------------
KEYSTONE_QA_ENABLED=true
KEYSTONE_QA_AUTO_APPROVE_THRESHOLD=0.90
KEYSTONE_QA_MAX_WORKERS=4
KEYSTONE_QA_TIMEOUT=300

# Available quality checks: topics, duration, gaps, images
# KEYSTONE_QA_CHECKS=topics,duration,gaps,images

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------
KEYSTONE_METRICS_ENABLED=true
KEYSTONE_METRICS_PORT=9090
KEYSTONE_HEALTH_CHECK_INTERVAL=10
KEYSTONE_LOG_LEVEL=debug
KEYSTONE_LOG_OUTPUT=/var/log/keystone-edge/

# -----------------------------------------------------------------------------
# Resource Limits
# -----------------------------------------------------------------------------
KEYSTONE_MAX_MEMORY_MB=6144
KEYSTONE_MAX_CPU_PERCENT=80
KEYSTONE_WORKER_COUNT=4

# -----------------------------------------------------------------------------
# Axon Transfer Server Configuration
# -----------------------------------------------------------------------------
KEYSTONE_AXON_TRANSFER_WS_PORT=8090
KEYSTONE_AXON_TRANSFER_MAX_EVENTS=10000
KEYSTONE_AXON_TRANSFER_READ_TIMEOUT=30

# -----------------------------------------------------------------------------
# Axon Recorder Server Configuration
# -----------------------------------------------------------------------------
KEYSTONE_AXON_RECORDER_WS_PORT=8091
KEYSTONE_AXON_RECORDER_PING_INTERVAL=30
KEYSTONE_AXON_RECORDER_RESPONSE_TIMEOUT=15
